# Single contact for Let's Encrypt ACME account. Set this once here; leave LETSENCRYPT_EMAIL
# empty on backend containers (or omit it). Repeating the same email on many containers makes
# acme-companion concatenate addresses → invalidContact / broken paths under /etc/acme.sh/.
DEFAULT_EMAIL=
NGINX_PROXY_CONTAINER=userver-nginx-proxy
# Leave NGINX_DOCKER_GEN_CONTAINER unset for nginxproxy/nginx-proxy (combined image). Only set it
# when docker-gen runs in a different container than nginx.
