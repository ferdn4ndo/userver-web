# Example Terraform variables for uServer-Web
# Copy this file to terraform.tfvars and modify as needed

# AWS Region
aws_region = "us-east-1"

# Network Configuration
vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"

# Security
ssh_allowed_cidr = "203.0.113.0/24"  # Replace with your IP or CIDR block

# EC2 Instance
ami_id        = "ami-0261755bbcb8c4a84"  # Ubuntu 20.04 LTS in us-east-1
instance_type = "t3.small"
key_name      = "your-ssh-key-name"  # Replace with your SSH key name

# Domain Names
monitor_domain = "monitor.example.com"  # Replace with your domain
whoami_domain  = "whoami.example.com"   # Replace with your domain

# DNS Configuration
create_dns_records = false  # Set to true to create DNS records in Route53
route53_zone_id    = ""     # Replace with your Route53 hosted zone ID if create_dns_records is true
