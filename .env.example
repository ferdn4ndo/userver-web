# --- Rootful Docker (typical Linux / Docker Desktop with root daemon) ---
# DOCKER_HOST_SOCK=/var/run/docker.sock
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443
# If dockergen gets "permission denied" on the socket, add to docker-compose.yml for the
# affected services:  group_add: [ "1001" ]  (use: stat -c '%g' /var/run/docker.sock)

# --- Rootless Docker (RootlessKit / dockerd in user session) ---
# Socket your `docker` CLI uses (adjust UID if not 1000):
DOCKER_HOST_SOCK=/run/user/1000/docker.sock
# Host ports must be >= 1024 unless you raise ip_unprivileged_port_start on the host.
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
# If bind fails (port already allocated), use other free ports, e.g. 8880 / 8843.
# Do not set DOCKER_SOCK_GID / group_add for rootless — runc often errors with setgroups.

# Run ALL related stacks with the same Docker CLI (do not mix sudo / different contexts).

# If nginx-proxy cannot read default.key:
#   sudo chmod 644 certs/default.key
